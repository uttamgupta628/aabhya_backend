# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/aabhya-foundation

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# First admin (used only by seed/seedAdmin.js)
ADMIN_NAME=Paritosh Shekhar Singh
ADMIN_EMAIL=admin@aabhyafoundation.org
ADMIN_PASSWORD=change_this_password

# Where new-donation / new-contact / new-volunteer-application alerts go (optional)
ADMIN_NOTIFICATION_EMAIL=admin@aabhyafoundation.org

# Stripe
# Run locally with: stripe listen --forward-to localhost:5000/api/webhooks/stripe

# SMTP (e.g. Gmail: smtp.gmail.com, port 587, use an App Password not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=info@kindflow.com
